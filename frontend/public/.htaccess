<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^api(/.*)?$ - [L]
  RewriteRule ^go-to-settings(/.*)?$ - [L]
  RewriteRule ^health(/.*)?$ - [L]
  RewriteRule ^static(/.*)?$ - [L]
  RewriteRule ^media(/.*)?$ - [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
