# Production example for atilahatefi.ir. Copy to .env.production and replace placeholders.
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-production-secret
DJANGO_ALLOWED_HOSTS=atilahatefi.ir,www.atilahatefi.ir
DJANGO_CSRF_TRUSTED_ORIGINS=https://atilahatefi.ir,https://www.atilahatefi.ir

# Same-origin production does not need CORS, but keep exact origins if cross-origin access is introduced.
DJANGO_CORS_ALLOWED_ORIGINS=https://atilahatefi.ir,https://www.atilahatefi.ir

# PostgreSQL is recommended for production. On small cPanel hosting, SQLite can be
# used with DATABASE_URL=sqlite:////home/USER/Portfolio/backend/db.sqlite3.
# Do not commit real credentials or production databases.
DATABASE_URL=postgresql://portfolio:replace-with-strong-database-password@127.0.0.1:5432/portfolio
DJANGO_DB_CONN_MAX_AGE=60
DJANGO_DB_CONN_HEALTH_CHECKS=True
DJANGO_DATABASE_SSL_REQUIRE=False

# Enable this only behind a trusted proxy that overwrites X-Forwarded-Proto.
DJANGO_USE_X_FORWARDED_PROTO=True
DJANGO_SECURE_SSL_REDIRECT=True

# Start with HSTS disabled. Increase only after HTTPS and redirects are verified.
DJANGO_HSTS_SECONDS=0
DJANGO_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_HSTS_PRELOAD=False

DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_STATIC_URL=/static/
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/srv/portfolio/shared/media
FRONTEND_DIST_DIR=/srv/portfolio/current/frontend/dist
FRONTEND_ASSET_MAX_AGE=31536000
DJANGO_ENABLE_WHITENOISE=True
DJANGO_USE_MANIFEST_STATICFILES=True
DJANGO_WHITENOISE_MAX_AGE=31536000
DJANGO_HEALTH_CHECK_DATABASE=True
DJANGO_LOG_LEVEL=INFO

# Gunicorn tuning. Increase workers according to CPU and memory.
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# Keep empty for same-origin production builds so React calls /api/ relatively.
VITE_API_BASE_URL=
