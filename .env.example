# Local development example. Copy to .env only if your shell or tooling loads it.
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=local-development-placeholder-only
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Leave empty for local SQLite development. Set for PostgreSQL testing.
DATABASE_URL=
DJANGO_DB_CONN_MAX_AGE=60
DJANGO_DB_CONN_HEALTH_CHECKS=True
DJANGO_DATABASE_SSL_REQUIRE=False

DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_USE_X_FORWARDED_PROTO=False
DJANGO_HSTS_SECONDS=0
DJANGO_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_HSTS_PRELOAD=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_LOG_LEVEL=DEBUG
DJANGO_HEALTH_CHECK_DATABASE=False
DJANGO_ENABLE_WHITENOISE=False
DJANGO_USE_MANIFEST_STATICFILES=False

# Keep empty for same-origin production builds. Local Vite uses its dev proxy.
VITE_API_BASE_URL=
